{
  "name": "lovetta",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "web"
  ],
  "scripts": {
    "start": "node server/index.js",
    "dev": "node scripts/run-dev.js",
    "dev:agent": "node scripts/run-dev-agent.js",
    "build": "npm -w web run build",
    "heroku-postbuild": "npm run build",
    "migrate": "node server/src/migrate.js",
    "kill:dev": "node scripts/kill-lovetta-runtime.js && node scripts/kill-ports.js 3900 5173",
    "kill:ports": "node scripts/kill-ports.js",
    "kill:runtime": "node scripts/kill-lovetta-runtime.js",
    "test:e2e": "npx playwright test --project=default",
    "test:e2e:api": "npx playwright test --project=api",
    "test:e2e:ai": "npx playwright test --project=ai",
    "test:e2e:ui": "npx playwright test --project=ui",
    "test:e2e:ai-real": "npx playwright test --project=ai-real",
    "test:e2e:demo": "npx playwright test --project=demo",
    "test:load": "node e2e/load-test.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1009.0",
    "@keyid/sdk": "^0.2.10",
    "@sentry/node": "^10.43.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "express": "^4.21.0",
    "express-rate-limit": "^7.5.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.0",
    "stripe": "^20.4.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "sharp": "^0.33.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
