{
  "appId": "ai.lovetta.app",
  "appName": "Lovetta",
  "webDir": "ios-dist",
  "server": {
    "appendUserAgent": "Capacitor lovetta-ios"
  },
  "ios": {
    "scheme": "Lovetta",
    "contentInset": "automatic",
    "backgroundColor": "#0f0a1a"
  },
  "plugins": {
    "Keyboard": {
      "resize": "body"
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    },
    "GoogleAuth": {
      "scopes": ["email", "profile"],
      "iosClientId": "1007256282722-jhi7vl1mj4jv12638fv5vh8ao9ribr3a.apps.googleusercontent.com",
      "serverClientId": "1007256282722-1n6bdvdcta96jf51bpajod0gjheo31ur.apps.googleusercontent.com",
      "forceCodeForRefreshToken": false
    }
  },
  "packageClassList": [
    "SignInWithApple",
    "CAPBrowserPlugin",
    "KeyboardPlugin",
    "PushNotificationsPlugin",
    "GoogleAuth",
    "PurchasesPlugin"
  ]
}
